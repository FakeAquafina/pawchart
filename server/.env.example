# PawChart Environment Configuration
# Copy this to .env and fill in your values

# Port the server listens on (Caddy will proxy to this)
PORT=3456

# Path to SQLite database file
DB_PATH=./pawchart.db

# Path to store uploaded receipt images/PDFs
UPLOADS_DIR=./uploads

# Ollama API URL — point this at your Ollama LXC's IP
# If Ollama is on the same machine: http://localhost:11434
# If Ollama is a separate LXC:      http://192.168.1.XXX:11434
OLLAMA_URL=http://192.168.1.XXX:11434

# Ollama model to use for JSON parsing
# llama3.2:3b is fast and works great for this task
# phi3:mini is a good alternative
OLLAMA_MODEL=llama3.2:3b

# Optional: restrict CORS to your domain (recommended for external access)
# ALLOWED_ORIGIN=https://pawchart.yourdomain.com
